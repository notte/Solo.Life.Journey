---
import { formatDate } from "@/utils/data.util";
import Tags from "./Tags.astro";

interface Props {
  title: string;
  author: string;
  tags: string[];
  minutesRead: string;
  pubDate: string;
}

const { title, pubDate, tags, minutesRead } = Astro.props;

const formattedDate = formatDate(pubDate);
---

<div class="flex flex-col items-center mb-10">
  <p
    class="leading-snug text-center text-4xl font-bold text-[#2a2235] dark:text-[#e8e0f0]"
  >
    {title}
  </p>
  <div class="py-4">
    <Tags tags={tags} withHref={true} />
  </div>
  <div class="text-sm text-[#8a7aa0] dark:text-[#9888b0]">
    <span>{formattedDate}</span> - <span>{minutesRead}</span>
  </div>
</div>
<hr class="hr mb-10" />
