---
import { formatDate } from "@/utils/data.util";

const { post, Content } = Astro.props;
---

<label
  class="flex h-full w-full flex-col rounded-[1rem] bg-[#e8e0f0] dark:bg-[#3c2f4e] p-10 cursor-pointer transition-transform duration-200 hover:-translate-y-1 hover:shadow-lg"
>
  <input type="checkbox" class="peer hidden" />
  <div class="flex items-start gap-3">
    <span class="text-3xl">{post.frontmatter.description}</span>
    <div>
      <p class="text-xs opacity-50">{formatDate(post.frontmatter.pubDate)}</p>
      <p>{post.frontmatter.title}</p>
    </div>
  </div>
  <div class="grid grid-rows-[0fr] peer-checked:grid-rows-[1fr] no-transition">
    <div class="overflow-hidden ml-11">
      <Content />
    </div>
  </div>
</label>

<style>
  .no-transition {
    transition: none;
  }
  .loaded .no-transition {
    transition: grid-template-rows 300ms ease-in-out;
  }
</style>

<script>
  window.addEventListener("load", () => {
    document.querySelectorAll(".no-transition").forEach((el) => {
      el.closest("label")?.classList.add("loaded");
    });
  });
</script>
